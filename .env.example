# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose "openai" or "anthropic"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# Set the key for your chosen provider (leave the other blank)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# Default: Docker Compose service. Override for external Postgres.
DATABASE_URL=postgresql://testflow:testflow@db:5432/testflow

# ── Security ──────────────────────────────────────────────────────────────────
# Random string, at least 32 characters
SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Azure DevOps (optional) ───────────────────────────────────────────────────
AZURE_DEVOPS_ORG=
AZURE_DEVOPS_PAT=
